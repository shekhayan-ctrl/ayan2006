## 2.Create a structure called FoodItem to store Zomato-style menu data: itemName (string), price (float), and rating (float). Initialize an array of 3 FoodItem variables with real menu items and display their details using a loop.


```c
#include <stdio.h>

struct FoodItem
{
    char itemName[50];
    float price;
    float rating;
};

int main()
{
    struct FoodItem menu[3] =
    {
        {"Paneer Biryani", 249.00, 4.5},
        {"Masala Dosa", 120.00, 4.3},
        {"Veg Pizza", 399.00, 4.7}
    };

    printf("Zomato Menu\n\n");

    for(int i = 0; i < 3; i++)
    {
        printf("Item %d\n", i + 1);
        printf("Name   : %s\n", menu[i].itemName);
        printf("Price  : ₹%.2f\n", menu[i].price);
        printf("Rating : %.1f\n\n", menu[i].rating);
    }

    return 0;
}
```

**Output:**

```text
Item 1
Name   : Paneer Biryani
Price  : ₹249.00
Rating : 4.5

Item 2
Name   : Masala Dosa
Price  : ₹120.00
Rating : 4.3

Item 3
Name   : Veg Pizza
Price  : ₹399.00
Rating : 4.7
```

