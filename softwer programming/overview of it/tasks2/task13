## 1.Create a file called playlist.txt and write the names of your top 3 favorite songs from Spotify into it using write mode (w).

```c
#include <stdio.h>

int main()
{
    FILE *fp;

    fp = fopen("playlist.txt", "w");

    if (fp == NULL)
    {
        printf("Error opening file!\n");
        return 1;
    }

    fprintf(fp, "Tum Hi Ho\n");
    fprintf(fp, "Kesariya\n");
    fprintf(fp, "Believer\n");

    fclose(fp);

    printf("Songs written successfully.\n");

    return 0;
}
```

